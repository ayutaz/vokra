# Vokra .gitattributes — pins committed binary fixtures to plain-blob storage.
#
# NFR-DS-02 / M2-06 §3 red-line: parity fixtures under tests/parity/whisper_*/
# and the audio input under tests/fixtures/audio/ MUST NOT be Git LFS pointers.
# Downstream consumers (parity_whisper.rs, the parity-whisper-real CI job,
# the openai-whisper-agreeing reference dumper, and future test binaries)
# rely on a plain `git clone` producing the actual bytes without needing
# `git lfs install` / `git lfs pull`. The `-filter` attribute clears any
# filter (including LFS's `filter=lfs`), so a stray `git lfs track "*.f32"`
# or `git lfs track "*.wav"` elsewhere in the tree cannot silently reroute
# these paths through the LFS pipeline.
#
# The `-diff` / `-merge` pins are additional guards: they prevent gitattributes
# filters (e.g. binary-diff drivers) from mangling the raw byte payloads.

# Whisper (and future model) parity f32 fixtures — see tests/parity/whisper_*/
tests/parity/whisper_*/*.f32 -filter -diff -merge
tests/parity/whisper_*/*.bin -filter -diff -merge

# RVQ codec parity fixtures (M4-04 T13/T14/T15) — same LFS-free contract.
# Consumed by crates/vokra-ops/tests/parity_{mimi,dac,encodec}_reference.rs
# and regenerated by tools/parity/mimi_dump.py.
tests/parity/mimi/*.f32 -filter -diff -merge
tests/parity/mimi/*.u32 -filter -diff -merge
tests/parity/dac/*.f32 -filter -diff -merge
tests/parity/dac/*.u32 -filter -diff -merge
tests/parity/encodec/*.f32 -filter -diff -merge
tests/parity/encodec/*.u32 -filter -diff -merge

# DeepFilterNet3 denoise primitive parity fixtures (M4-20 T17) — same
# LFS-free contract. Consumed by crates/vokra-ops/src/denoise.rs
# (primitive_parity tests) and regenerated by
# tools/parity/dfn3_primitives_fixture.py.
tests/parity/dfn3/*.f32 -filter -diff -merge

# FSQ codec parity fixtures (M4-16 T10/T11) — same LFS-free contract.
# Consumed by crates/vokra-ops/tests/parity_fsq_codec.rs and regenerated by
# tools/parity/fsq_dump.py (wavtokenizer / xcodec2 subcommands).
tests/parity/fsq/*/*.f32 -filter -diff -merge
tests/parity/fsq/*/*.u32 -filter -diff -merge

# Voxtral parity fixtures (M3-10-T19/T20) — same LFS-free contract.
# Consumed by crates/vokra-models/tests/parity_voxtral.rs and regenerated by
# tools/parity/dump_voxtral_reference.py.
tests/parity/voxtral/*.f32 -filter -diff -merge
tests/parity/voxtral/*.bin -filter -diff -merge

# Real-audio input consumed by tools/parity/dump_whisper_reference.py.
tests/fixtures/audio/*.wav -filter -diff -merge

# Silero VAD parity inputs (synthetic test_{8,16}k.wav + the decimated
# real-speech jfk-30s-8k.wav) and the fixture GGUF. Same LFS-free contract:
# crates/vokra-models/src/silero_vad/parity.rs reads these bytes directly.
tests/parity/silero_vad/*.wav -filter -diff -merge
tests/parity/silero_vad/*.gguf -filter -diff -merge

# C ABI raw-PCM fixtures (mirror of the whisper input_pcm.f32; see
# tests/capi/fixtures/gen_fixtures.py). Same LFS-free contract.
tests/capi/fixtures/*.f32 -filter -diff -merge

# M4-03 aec parity fixtures (raw int16 LE PCM; see tools/parity/aec_dump.py
# and crates/vokra-ops/tests/parity_aec.rs). Same LFS-free contract.
tests/parity/aec/*.i16le -filter -diff -merge

# Vulkan precompiled SPIR-V blobs (M4-13-T16) — same LFS-free contract.
# Embedded via include_bytes! in crates/vokra-backend-vulkan/src/spirv.rs
# (SHA-256-pinned there and in SHA256SUMS); regenerated ONLY by
# scripts/compile-vulkan-shaders.sh --update with the toolchain pinned in
# kernels/precompiled/PROVENANCE.
crates/vokra-backend-vulkan/kernels/precompiled/*.spv -filter -diff -merge
