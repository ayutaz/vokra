# Unity crash/log artifacts.
sysinfo.txt
*.stackdump
crashlog*.txt

# IDE / solution files regenerated by Unity.
*.csproj
*.sln
*.suo
*.user
*.userprefs
.vs/
.idea/
.vsconfig

# Native plugins are placed by scripts/build-unity-plugin.sh — not committed
# (they are build artifacts of the vokra-capi crate).
Assets/Plugins/**/libvokra.*
Assets/Plugins/**/vokra.dll
Assets/Plugins/**/*.dylib
Assets/Plugins/**/*.so
Assets/Plugins/**/*.dll

# Demo models + generated test audio are placed by scripts/fetch-demo-models.sh —
# not committed (large / uncommitted GGUFs; generated WAV).
Assets/StreamingAssets/models/*.gguf
Assets/StreamingAssets/*.wav
Assets/StreamingAssets/piper-plus-g2p/
