[gd_scene load_steps=2 format=3 uid="uid://vokra_asr_demo_main"]

; Vokra ASR demo main scene (M3-11-T14).
;
; Node tree:
;   Main (Control)             ← root, script = res://main.gd
;   └── VBoxContainer
;       ├── StatusLabel        ← current phase (loading / running / done)
;       ├── TranscriptLabel    ← final transcription output
;       └── LoadButton         ← Button, triggers ASR run on press
;
; Runtime verification in the Godot 4.x Editor is M3-11-T19 owner work.

[ext_resource type="Script" path="res://main.gd" id="1_main"]

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_main")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = -16.0

[node name="StatusLabel" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = "Ready. Press Transcribe to run Whisper base on res://audio/jfk.wav."

[node name="TranscriptLabel" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = ""
autowrap_mode = 3

[node name="LoadButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
text = "Transcribe"

[connection signal="pressed" from="VBoxContainer/LoadButton" to="." method="_on_transcribe_pressed"]
