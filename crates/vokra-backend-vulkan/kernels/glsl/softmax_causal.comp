// softmax_causal.comp — M3-02-T16 (causal-masked softmax).
// For decoder self-attention: `y[i,j] = softmax(x[i,j])` over j = 0..=i;
// masked cols j > i receive `exp(-inf) = 0`.
//
// Bit-identical vs "host-mask + softmax": the mask column contributes `-inf`
// to the max reduction (harmless — no other value is -inf in practice) and
// `exp(-inf) = 0` to both the sum and the output. This matches the CPU / Metal
// / CUDA implementations' IEEE-754 behaviour (CLAUDE.md).
//
// Compile with:
//   glslc --target-env=vulkan1.1 -o precompiled/softmax_causal.spv glsl/softmax_causal.comp

#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PC {
    uint rows;
    uint cols;
} pc;

layout(std430, set = 0, binding = 0) readonly buffer InBuf  { float in_buf[];  };
layout(std430, set = 0, binding = 1) writeonly buffer OutBuf { float out_buf[]; };

void main() {
    uint row = gl_WorkGroupID.x;
    uint lane = gl_SubgroupInvocationID;
    uint sg_size = gl_SubgroupSize;
    if (row >= pc.rows) {
        return;
    }
    // Row `i` has legal columns j = 0..=i (inclusive); j > i is masked.
    uint valid_cols = row + 1u;
    if (valid_cols > pc.cols) {
        valid_cols = pc.cols;
    }
    // Pass 1: row-wise max over valid cols. For masked cols the contribution
    // is `-inf` (via exp(-inf)=0 below), so we only reduce over valid cols
    // here — equivalent to including `-inf` in the reduction (no-op).
    float lane_max = -3.402823e38;
    for (uint j = lane; j < valid_cols; j += sg_size) {
        lane_max = max(lane_max, in_buf[row * pc.cols + j]);
    }
    float row_max = subgroupMax(lane_max);
    // Pass 2: row-wise sum of exp(x - max) over valid cols only.
    float lane_sum = 0.0;
    for (uint j = lane; j < valid_cols; j += sg_size) {
        lane_sum += exp(in_buf[row * pc.cols + j] - row_max);
    }
    float row_sum = subgroupAdd(lane_sum);
    float inv_sum = 1.0 / row_sum;
    // Pass 3: write y — valid cols get the softmax value, masked cols get 0.
    for (uint j = lane; j < pc.cols; j += sg_size) {
        if (j < valid_cols) {
            out_buf[row * pc.cols + j] =
                exp(in_buf[row * pc.cols + j] - row_max) * inv_sum;
        } else {
            out_buf[row * pc.cols + j] = 0.0;
        }
    }
}
