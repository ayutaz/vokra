class Vokra < Formula
  desc "Speech-first inference runtime (ONNX Runtime alternative for speech AI)"
  homepage "https://github.com/ayutaz/vokra"
  url "@@BASE_URL@@/@@VERSION@@-src.tar.gz"
  sha256 "@@SHA256:src@@"
  license "Apache-2.0"
  version "@@VERSION@@"

  depends_on "rust" => :build

  def install
    system "cargo", "build", "--release", "--locked", "-p", "vokra-cli"
    bin.install "target/release/vokra-cli" => "vokra"
  end

  test do
    assert_match "vokra", shell_output("#{bin}/vokra --help 2>&1", 2)
  end
end
